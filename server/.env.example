DATABASE_URL="file:./dev.db"
PORT=3000

# 部署到生产时设为 production：会关闭 /api/docs 接口文档等仅开发用途的入口。
# NODE_ENV="production"

# 管理员引导：无需配置。空系统里第一个注册的用户会自动成为管理员（first-run），此后注册均为普通用户。

# 鉴权：access token 使用 JWT 短期签名，refresh token 仅通过 HttpOnly Cookie 保存。
# JWT_ACCESS_SECRET 至少 32 个字符，生产环境请使用随机高强度密钥。
JWT_ACCESS_SECRET="replace_with_at_least_32_random_chars"
ACCESS_TOKEN_TTL_MINUTES=15

# AI 服务：任意 OpenAI 兼容端点（chat/completions）。地址与模型必须显式配置。
AI_API_KEY="your_api_key_here"
AI_BASE_URL="https://api.openai.com/v1"
AI_MODEL_FAST="gpt-4o-mini"
AI_MODEL_QUALITY="gpt-4o"
# 仅当服务支持推理开关（如 DeepSeek 的 thinking）时设为 true；纯 OpenAI 保持 false。
AI_SEND_THINKING="false"

# DeepSeek 示例（把上面几项换成）：
# AI_API_KEY="sk-..."
# AI_BASE_URL="https://api.deepseek.com"
# AI_MODEL_FAST="deepseek-chat"
# AI_MODEL_QUALITY="deepseek-reasoner"
# AI_SEND_THINKING="true"