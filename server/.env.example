DATABASE_URL="file:./dev.db"
PORT=3000

# 管理员引导：逗号分隔的邮箱。服务启动时把名单内的【已注册】用户置为 admin（只升不降）。
# 顺序：先注册 → 邮箱填这里 → 重启服务生效。
ADMIN_EMAILS=""

# AI 服务：任意 OpenAI 兼容端点（/chat/completions）。地址与模型必须显式配置。
AI_API_KEY="your_api_key_here"
AI_BASE_URL="https://api.openai.com/v1"
AI_MODEL_FAST="gpt-4o-mini"
AI_MODEL_QUALITY="gpt-4o"
# 仅当服务支持推理开关（如 DeepSeek 的 thinking）时设为 true；纯 OpenAI 保持 false。
AI_SEND_THINKING="false"

# DeepSeek 示例（把上面几项换成）：
# AI_API_KEY="sk-..."
# AI_BASE_URL="https://api.deepseek.com"
# AI_MODEL_FAST="deepseek-chat"
# AI_MODEL_QUALITY="deepseek-reasoner"
# AI_SEND_THINKING="true"
