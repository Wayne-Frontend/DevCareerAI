generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id           String   @id @default(cuid())
  username     String   @unique
  email        String   @unique
  profession   String?
  avatarUrl    String?
  passwordHash String
  role         String   @default("user") // 'user' | 'admin'，SQLite 不支持原生 enum，用字符串 + 应用层约束
  status       String   @default("active") // 'active' | 'disabled'，disabled 禁止登录并即时吊销会话
  // 管理员重置密码后置为 true：临时密码为管理员可见，强制用户改密后才能使用其他功能
  mustChangePassword Boolean @default(false)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  sessions             AuthSession[]
  resumes              Resume[]
  projectOptimizations ProjectOptimization[]
  jobDescriptions      JobDescription[]
  interviewSessions    InterviewSession[]
  chatSessions         ChatSession[]
}

model AuthSession {
  id                  String    @id @default(cuid())
  refreshTokenHash    String    @unique
  refreshTokenVersion Int       @default(0)
  userId              String
  expiresAt           DateTime
  revokedAt           DateTime?
  createdAt           DateTime  @default(now())
  lastUsedAt          DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
  @@index([revokedAt])
}

model Resume {
  id              String   @id @default(cuid())
  userId          String?
  title           String
  content         String
  fileName        String?
  fileType        String?
  targetRole      String?
  experienceLevel String?
  source          String   @default("manual") // manual=用户保存，auto=匹配/面试临时创建
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  user         User?                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  analyses     ResumeAnalysis[]
  jobMatches   JobMatchAnalysis[]
  interviews   InterviewSession[]
  chatSessions ChatSession[]

  @@index([userId])
}

model ResumeAnalysis {
  id         String   @id @default(cuid())
  resumeId   String
  score      Int
  resultJson Json
  createdAt  DateTime @default(now())

  resume Resume @relation(fields: [resumeId], references: [id], onDelete: Cascade)

  @@index([resumeId])
}

model ProjectOptimization {
  id         String   @id @default(cuid())
  userId     String?
  rawContent String
  targetRole String?
  techStack  Json?
  style      String?
  resultJson Json
  createdAt  DateTime @default(now())

  user User? @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model JobDescription {
  id          String   @id @default(cuid())
  userId      String?
  jobTitle    String
  companyName String?
  content     String
  source      String   @default("manual") // manual=用户保存，auto=匹配/面试临时创建
  createdAt   DateTime @default(now())

  user         User?                @relation(fields: [userId], references: [id], onDelete: Cascade)
  matches      JobMatchAnalysis[]
  interviews   InterviewSession[]
  chatSessions ChatSession[]

  @@index([userId])
}

model JobMatchAnalysis {
  id               String   @id @default(cuid())
  resumeId         String
  jobDescriptionId String
  matchScore       Int
  resultJson       Json
  createdAt        DateTime @default(now())

  resume         Resume         @relation(fields: [resumeId], references: [id], onDelete: Cascade)
  jobDescription JobDescription @relation(fields: [jobDescriptionId], references: [id], onDelete: Cascade)

  @@index([resumeId])
  @@index([jobDescriptionId])
}

model InterviewSession {
  id               String   @id @default(cuid())
  userId           String?
  resumeId         String?
  jobDescriptionId String?
  title            String
  targetRole       String?
  interviewType    String
  difficulty       String
  status           String   @default("ongoing") // 'ongoing' | 'summarizing' | 'finished'，summarizing 为总结生成中的过渡态
  summaryJson      Json?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  user           User?              @relation(fields: [userId], references: [id], onDelete: Cascade)
  resume         Resume?            @relation(fields: [resumeId], references: [id], onDelete: SetNull)
  jobDescription JobDescription?    @relation(fields: [jobDescriptionId], references: [id], onDelete: SetNull)
  messages       InterviewMessage[]

  @@index([userId])
}

model InterviewMessage {
  id           String   @id @default(cuid())
  sessionId    String
  role         String
  content      String
  feedbackJson Json?
  // 会话内单调递增的消息序号，保证排序稳定；历史数据为 0，靠 createdAt 兜底。
  seq          Int      @default(0)
  createdAt    DateTime @default(now())

  session InterviewSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([sessionId, createdAt])
  @@index([sessionId, seq])
}

model ChatSession {
  id               String   @id @default(cuid())
  userId           String?
  resumeId         String?
  jobDescriptionId String?
  title            String   @default("新的会话")
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  user User? @relation(fields: [userId], references: [id], onDelete: Cascade)
  // 删除简历/JD 不应连带删除聊天记录，故用 SetNull。
  resume         Resume?          @relation(fields: [resumeId], references: [id], onDelete: SetNull)
  jobDescription JobDescription?  @relation(fields: [jobDescriptionId], references: [id], onDelete: SetNull)
  messages       ChatMessage[]

  @@index([userId, updatedAt])
}

model ChatMessage {
  id        String   @id @default(cuid())
  sessionId String
  role      String // 'user' | 'ai'，与 InterviewMessage 保持一致
  content   String
  createdAt DateTime @default(now())

  session ChatSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([sessionId, createdAt])
}

model AiCache {
  id         String   @id @default(cuid())
  cacheKey   String   @unique
  feature    String
  model      String
  version    String   @default("v1")
  promptHash String
  resultJson Json
  rawText    String?
  createdAt  DateTime @default(now())
  expiresAt  DateTime?

  @@index([feature, model])
  @@index([promptHash])
  @@index([expiresAt])
}

model AiUsageLog {
  id               String   @id @default(cuid())
  userId           String?
  feature          String
  model            String
  promptTokens     Int      @default(0)
  completionTokens Int      @default(0)
  totalTokens      Int      @default(0)
  // 'reported' = AI 服务上报的精确值；'estimated' = usage 丢失（如流式断连）时按文本长度估算的兜底值。
  usageSource      String   @default("reported")
  createdAt        DateTime @default(now())

  @@index([userId])
  @@index([feature, createdAt])
  @@index([createdAt])
}